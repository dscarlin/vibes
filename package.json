{
  "name": "vibes-platform",
  "private": true,
  "workspaces": [
    "server",
    "worker",
    "web"
  ],
  "scripts": {
    "dev": "node server/src/index.js",
    "worker": "node worker/src/index.js",
    "agent-task": "node ./scripts/agent-task/index.mjs run",
    "agent-task:resume": "node ./scripts/agent-task/index.mjs resume",
    "agent-task:cleanup": "node ./scripts/agent-task/index.mjs cleanup",
    "agent-task:janitor": "node ./scripts/agent-task/index.mjs janitor",
    "test:agent-task": "node --test ./scripts/agent-task/*.test.mjs"
  },
  "devDependencies": {
    "@openai/codex": "^0.104.0"
  }
}
